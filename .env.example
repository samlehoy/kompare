# Kompare environment variables
# Copy this file to .env and fill in your values.
# DO NOT commit .env to git — it's gitignored.

# Google Gemini API key for PC Builder advisor and build-audit features.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional key pool. Runtime Gemini calls try keys in order and rotate to the
# next key when Gemini reports quota or rate-limit exhaustion.
# GEMINI_API_KEY_1=your-first-gemini-api-key
# GEMINI_API_KEY_2=your-second-gemini-api-key
# GEMINI_API_KEY_3=your-third-gemini-api-key
# GEMINI_API_KEY_4=your-fourth-gemini-api-key

# === OPTIONAL ===

# Chat session persistence: "memory" (default) or "file"
CHAT_PERSIST=memory

# Paste-URL fetch timeout (seconds)
URL_FETCH_TIMEOUT=10

# User-Agent header for paste-URL fetch
URL_FETCH_USER_AGENT=Mozilla/5.0 (compatible; SmartShoppingBot/1.0)

# Scraper delay between enterkomputer.com requests (seconds)
SCRAPER_DELAY_SEC=2

# Default UI locale and currency
DEFAULT_LOCALE=id-ID
DEFAULT_CURRENCY=IDR

# Gemini request delay for legacy/offline data tooling (seconds)
GEMINI_REQUEST_DELAY_SEC=1

# Runtime Gemini model used by /build/advisor and image-backed /build/audit.
# Defaults to gemini-2.5-flash-lite (much higher free-tier RPD than -flash).
# If you have paid quota, switch to gemini-2.5-flash for better quality.
GEMINI_MODEL=gemini-2.5-flash-lite

# === AI/RAG provider profile switch ===

# Active AI profile. Valid values:
# - gemini_free: current Gemini + local JSON vector index path.
# - local_qwen: LM Studio Qwen + Qdrant collection.
KOMPARE_AI_PROFILE=gemini_free

# Gemini vector index path used by the existing local JSON index.
GEMINI_VECTOR_INDEX_PATH=data/vector_index

# LM Studio local model profile.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_LLM_MODEL=qwen/qwen3.6-27b
LMSTUDIO_EMBEDDING_MODEL=text-embedding-qwen3-embedding-4b
# Keep this low enough that the web route falls back quickly when a local model
# is loaded but not strict-JSON ready.
LMSTUDIO_TIMEOUT_SECONDS=90

# Qdrant target for the local_qwen profile.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_QWEN=kompare_components_qwen
QDRANT_VECTOR_SIZE=2560
QDRANT_DISTANCE=cosine
